    <script>

        function GoBack(url) {
        window.location.href = url;
        }

        function swalAlertOnly(vartitle, vartext, varType) {
            swal({
                title: vartitle,
                text: vartext,
                type: varType
            });
        }

        function swalConfirm(vartitle, vartext, varType, callback) {
            swal({
                title: vartitle,
                text: vartext,
                type: varType,
                showCancelButton: true,
                confirmButtonText: "Yes",
                cancelButtonText: "No"
            },
            function(isConfirm) {
                if (isConfirm) {
                    callback();
                }
            });
        }


        function swalWithRedirect(vartitle, vartext, varType, varUrl) {
            swal({
                title: vartitle,
                text: "You will be redirected to " + vartext + " after clicking (OK)",
                type: varType
            },
            function () {
                window.location.href = varUrl;
            });
        }

        $('.input-daterange').datepicker({
        keyboardNavigation: false,
        forceParse: false,
        autoclose: true
        });


    </script>
