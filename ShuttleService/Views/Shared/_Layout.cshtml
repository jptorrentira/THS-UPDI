                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="surveyForm"></div>

    <partial name="_CookieConsentPartial" />



    <div class="modal fade" id="loading" tabindex="-1" role="dialog" data-backdrop="false" data-keyboard="false">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-body">

                    <span class="fa fa-spin fa-spinner"></span> Loading...

                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="SurveyModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
        <div class="modal-dialog modal-md" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <label>Answer Survey - <b style="color:#1ab394" id="surveyTransId"></b></label>
                </div>
                <div class="modal-body">
                    <form class="formSurvey"><input type="hidden" name="HashCode" readonly value="" /></form>

                    <div id="formSurveyDiv"><label>Loading survey....</label></div>
                </div>
                <div class="modal-footer">
                    <btn class="btn btn-primary" id="submitBtnSurvey">Submit</btn>
                    <btn class="btn btn-danger" data-dismiss="modal">Cancel</btn>
                </div>
            </div>
        </div>
    </div>
</body>

</html>

<script>
    $.fn.dataTable.ext.errMode = 'none';
    $.fn.modal.Constructor.prototype.enforceFocus = function () { };

    jQuery(document).ready(function () {
        
        var height = window.innerHeight;
        var footerHeight = $('footer').outerHeight();
        //$('.main').css('min-height', (height +'px'));
    });



    $(document).ajaxStart(function () {
        $("#wait").css("display", "block");
        //$("#ModalLoading").removeClass("hidden");
        //$("#ModalLoadingSMS").removeClass("hidden");
        //$("#loading").removeClass("hidden");
        //$(".modal-backdrop").removeClass("hidden");
    });
    $(document).ajaxComplete(function () {

        //$("#ModalLoading").modal("hide");
        //$("#ModalLoading").modal("hide");
        $("#wait").css("display", "none");
        $("#ModalLoading").css("display", "none");
        $("#ModalLoadingSMS").css("display", "none");
        $("#loading").css("display", "none");


        //$("#ModalLoading").addClass("hidden");

        //$("#ModalLoadingSMS").modal("hide");
        //$("#ModalLoadingSMS").modal("hide");
        //$("#ModalLoadingSMS").addClass("hidden");

        //$("#loading").modal("hide");
        //$("#loading").addClass("hidden");

        //$(".modal-backdrop").addClass("hidden");
        //$('body').removeClass('modal-open');


    });


    $(window).resize(function () {
        $('.dataTable').DataTable().columns.adjust().responsive.recalc();
    });

    $(".clockpicker").clockpicker({
        //twelvehour: true
    });

    function checkRequiredForm(form) {
        var x = true;
        $(".has-error").removeClass("has-error");
        $("#" + form + " :input").each(function (index) {

            if ($(this).hasClass("required") && $.trim($(this).val()) == "" && x == true) {
                //alert($(this).hasClass("required") + "-" + $.trim($(this).val()) + "-" + x + "-" + $(this).attr("name"));
                //$(this).closest(".form-group").addClass("has-error");
                x = false;
                //alert(this.name);
            }
        });
        return x;
    }


    function checkRequiredFormClass(form) {
        var x = true;
        $(".has-error").removeClass("has-error");
        $("." + form + " :input").each(function (index) {
            if ($(this).hasClass("required") && $.trim($(this).val()) == "" && x == true) {
                x = false;
            }
        });
        return x;
    }


    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }



    function checkSurveys() {
        //returnType -> 1 for displaying of survey list -> 2 for counting the surveys
      

           $.ajax({
            type: "POST",
            url: "@Url.Content("~/SurveyTransactions/CheckSurveyCounts")",
            dataType: "JSON",
            async: false,
               success: function (data, textStatus, jqXHR) {
                   $(".surveyAll").addClass("hidden");
                   $(".PendingSurveyList").html('');
                   surveyCount = data.surveyCount;
                   if (data.surveyCount > 0) {
                       $(".surveyAll").removeClass("hidden");
                       $("#PendingSurveys").text(""+data.surveyCount);
                       $(".PendingSurveyList").append('<li>&nbsp;Pending Surveys</li>');
                       $.each(data.surveys, function (x, v) {
                           $(".PendingSurveyList").append('<a href="#" onclick="answerSurvey(`' + v['surveyHash'] + '`,`' + v['transactionId'] +'`);">'+
                           '<div>'+
                               '<i class="fa fa-credit-card"></i>&nbsp; ' + v['transactionId']+
                           '</div>' +
                            '</a>');
                       });
                   }
            }
        });

     
    }
    checkSurveys();

    //setInterval(function () {
    //    checkSurveys();
    //}, 5000);

    function answerSurvey(hash, surveyTransId) {
        $("#surveyTransId").text(surveyTransId);
        $("#formSurveyDiv").html('');
        $("#formSurveyDiv").append('<label>Loading Survey...</label>');
        $(".formSurvey [name='HashCode']").val(hash).change();
        $("#formSurveyDiv").load('@Url.Action("AnswerSurvey","SurveyTransactions")' + "?u="+hash);
        $("#SurveyModal").modal("show");
    }




    $("#submitBtnSurvey").click(function () {

        if (checkRequiredFormClass("formSurvey") == false) {
            swalAlertOnly("Error", "Please complete all details", "error");
            return false;
        }


         swal({
                title: "Are you sure?",
                text: "Submit survey",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Proceed!",
                closeOnConfirm: false
            }, function () {
                    $("#ModalLoading").modal("show");
                    $("#ModalLoading").css('display', 'block');
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("SaveSurvey","SurveyTransactions")?id=",
                        data: $(".formSurvey").serialize(),
                        //"contentType": "application/json; charset=utf-8",
                        dataType: "JSON",
                        success: function (data, textStatus, jqXHR) {
                            if (data.success == 1) {
                                $("#SurveyModal").modal("hide");
                                swalAlertOnly("Success", data.message, "success");
                            } else {
                                swalAlertOnly("Error", data.message, "error");
                            }
                            checkSurveys();
                        }
                    });
            });

    });



    if ('@_location' == "makati" || '@_location' == 'minesite') {
        $(".makati").removeClass('hidden');
        $(".calaca").addClass('hidden');
    }
    else if ('@_location' == "calaca") {
        $(".makati").addClass('hidden');
        $(".calaca").removeClass('hidden');
    }
    else {

    }

    //for makati
    //$(".calaca").addClass('hidden');
    //$(".makati").removeClass('hidden');

    //for calaca
    //$(".calaca").removeClass('hidden');
    //$(".makati").addClass('hidden');
  
    if ('@ViewBag.Hash' != '')
    {
        answerSurvey('@ViewBag.Hash', '@ViewBag.TransId');
    }
</script>
