@{
    @inject SignInManager<ApplicationUser> SignInManager;
    @inject UserManager<ApplicationUser> UserManager;
    @using Microsoft.AspNetCore.Identity
    @using ShuttleService.Models


    @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor;

    var fullname = "";
    var employeeId = "";
    var companyGroup = "";
    foreach (var cookie in HttpContextAccessor.HttpContext.Request.Cookies)
    {
        if (@cookie.Key == "fullname")
        {
            fullname = cookie.Value;
        }
        if (@cookie.Key == "employeeId")
        {
            employeeId = cookie.Value;
        }
        if (@cookie.Key == "companyGroup")
        {
            companyGroup = cookie.Value;
        }
    }

    @using Microsoft.AspNetCore.Http
    @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

    var _location = @HttpContextAccessor.HttpContext.Session.GetString("Session_location");


