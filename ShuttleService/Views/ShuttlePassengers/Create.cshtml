    function EmployeeSearchAjax(empid) {
     
        var l = $('#EmployeeSearchByName').ladda();
            l.ladda('start');
            $.ajax({
                    type: "POST",
                url: "@Url.Content("~/employees/checkEmployee")?employeeId=" + $.trim(empid)  +"&d=@ViewBag.dGet",
                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                       
                        if (data.error != 1) {
                         
                            $("#PassengerTypeId").val("1").change();
                            $("#Gender").val(data['data'].gender).trigger("change");
                            $("#EmployeeNo").val(empid);
                            $("#FirstName").val(data['data'].firstName);
                            $("#MiddleName").val(data['data'].middleName);
                            $("#LastName").val(data['data'].lastName);
                            $("#Position").val(data['data'].position);
                            $("#CompanyListId").val(data['data'].companyListId).change();
                            $("#ChargingCompanyId").val(data['data'].chargingCompanyId).change();
                            $("#ChargingDepartmentId").append("<option value='" + data.chargingDepartmentId + "'>" + data.chargingDepartment + "</option>").val(data.chargingDepartmentId).change();
                            CheckCompanyList();
                            DisableLookupElement();

                        } else {
                            $("#Name").val("");
                            $("#Position").val("");
                            $("#CompanyListId").val("").change();;
                            swalAlertOnly("Error", "Employee not found", "error");
                        }

                        l.ladda('stop');

                        $("#ModalEmployeeFilter").modal("hide");
                    }
        });

    }


