@model ShuttleService.Models.ShuttlePassenger;
@Html.ValidationMessageFor(m => m.CompanyOther)
@{
    ViewData["Title"] = "Shuttle Service Form";
}

<style>
    #tableEmployee_length {
        visibility: hidden;
    }
</style>
<div class="wrapper-content row">
    <div class="col-md-6">
        <h4>Shuttle Service Form</h4>
    </div>
    <div class="col-md-6 ">
        <div class="btn-group pull-right">
            @if (ViewBag.OverAllApprover == 1)
            {
                <button type="button" class="btn btn-w-m btn-primary" onclick="Submit();">Submit & Approve</button>
            }
            else
            {
                <button type="button" class="btn btn-w-m btn-primary" onclick="Submit();">Submit</button>

            }
            @if (ViewBag.FromTrip == "1")
            {

                <button type="button" class="btn btn-w-m btn-danger" onclick="GoBack('@Url.Content("~/trips/details?d=")@ViewBag.dGet')">Back</button>

            }
            else
            {
                <button type="button" class="btn btn-w-m btn-danger" onclick="GoBack('@Url.Content("~/shuttlepassengers/details?d=")@ViewBag.dGet')">Back</button>
            }
        </div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight white-bg">
    <form asp-action="Create" id="ShuttleForm" class="form-horizontal">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input name="ServiceDateTimeStamp" type="hidden" readonly value="@ViewBag.dGet" />
        <div class="row">
            <div class="col-md-6">
                <h3 style="color:#1ab394">Charging</h3>
                <hr />
            </div>

        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ChargingCompanyId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="ChargingCompanyId" class="form-control input-sm select2" onchange="checkChargingDepartment()" asp-items="ViewBag.ChargingCompanyId">
                            <option value="" selected>--Please Select--</option>
                        </select>

                        <span asp-validation-for="ChargingCompanyId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="ChargingDepartmentId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="ChargingDepartmentId" class="form-control input-sm select2" >
                            <option value="" selected>--Please Select--</option>
                        </select>
                        <span asp-validation-for="ChargingDepartmentId" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <h3 style="color:#1ab394">Passenger Entry</h3>
                <hr />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group hidden">
                    <label asp-for="ShuttleId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="ShuttleId" class="form-control input-sm select2" asp-items="ViewBag.ShuttleId"></select>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="PassengerTypeId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="PassengerTypeId" onchange="ValidatePassengerType();" class="form-control input-sm lookupElement select2" asp-items="ViewBag.PassengerTypeId"></select>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="EmployeeNo" class="control-label col-sm-3"></label>
                    <div class="col-sm-6">
                        <input asp-for="EmployeeNo" class="form-control lookupElement" onblur="$('#EmployeeSearch').trigger('click');" />
                        <span asp-validation-for="EmployeeNo" class="text-danger"></span>
                    </div>
                    <div class="col-sm-1 pull-left">
                        <a onclick="resetLookupElement();" class="btn btn-danger" data-style="expand-left">Clear</a>
                    </div>
                    <div class="col-sm-1 pull-left">
                        <a id="EmployeeSearch" class="ladda-button btn btn-primary" data-style="expand-left">Search</a>
                    </div>
                </div>
                <div class="form-group" id="divForCompanyID">
                    <label asp-for="CompanyListId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="CompanyListId" class="form-control input-sm lookupElement select2" asp-items="ViewBag.CompanyId" onchange="CheckCompanyList();">
                            <option value="" selected>--Please Select--</option>
                        </select>
                        <span asp-validation-for="CompanyListId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="CompanyOther" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="CompanyOther" id="CompanyOther" disabled class="form-control lookupElement" />
                        <span asp-validation-for="CompanyOther" class="text-danger"></span>
                    </div>
                </div>

                <hr />
                <div class="form-group">
                    <label asp-for="FirstName" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="FirstName" id="FirstName" class="form-control lookupElement" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="MiddleName" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="MiddleName" id="MiddleName" class="form-control lookupElement" />
                        <span asp-validation-for="MiddleName" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="LastName" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="LastName" id="LastName" class="form-control lookupElement" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-sm-8">
                    </div>
                    <div class="col-sm-1 pull-left">
                        <a onclick="resetLookupElement();" class="btn btn-danger" data-style="expand-left">Clear</a>
                    </div>
                    <div class="col-sm-1 pull-left">
                        <a id="EmployeeSearchByName" onclick="ShowEmployeeByName();" class="btn btn-primary" data-style="expand-left">Search</a>
                    </div>
                </div>

                <hr />

                <div class="form-group ContactNoGroup hidden lookupElement">
                    <label asp-for="Nationality" class="control-label col-md-3"></label>
                    <div class="col-md-8">
                        <select asp-for="Nationality" class="form-control input-sm lookupElement select2" asp-items="ViewBag.Nationality"></select>
                    </div>
                </div>

                <div class="form-group ContactNoGroup hidden lookupElement">
                    <label asp-for="Gender" class="control-label col-md-3"></label>
                    <div class="col-md-8">
                        <select asp-for="Gender" class="form-control select2">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>


                <div class="form-group ContactNoGroup hidden">
                    <label asp-for="ContactNo" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="ContactNo" class="form-control lookupElement" />
                        <span asp-validation-for="ContactNo" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Position" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="Position" class="form-control lookupElement" />
                        <span asp-validation-for="Position" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Purpose" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="Purpose" class="form-control" />
                        <span asp-validation-for="Purpose" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Remarks" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <input asp-for="Remarks" class="form-control" />
                        <span asp-validation-for="Remarks" class="text-danger"></span>
                    </div>
                </div>



            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label name="ServiceDate" class="control-label col-sm-3">Service Date</label>
                    <div class="col-sm-8">
                        <input name="ServiceDate" class="form-control input-sm" readonly style="background-color: white !important;" value="@ViewBag.dtimestamp" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="TripTypeId" class="control-label col-sm-3"></label>
                    <div class="col-sm-8">
                        <select asp-for="TripTypeId" class="form-control select2" asp-items="ViewBag.TripTypeId" onchange="checkLodging(this);"></select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-sm-3">Call Time</label>
                    <div class="col-sm-8">
                        <label class="control-label" style="color:red;font-style:italic;">Varies on the day and vehicle to be used. Please refer to the guidelines.</label>
                    </div>
                </div>
                <div class="form-group">
                    <label class="control-label col-sm-3">Lodging From</label>
                    <div class="col-sm-8">
                        <div class=" input-group hidden" id="Lodgingdatepicker">
                            <input id="LodgingFrom" type="text" class="input-sm form-control" readonly name="LodgingFrom" value="@ViewBag.dtimestamp">
                            <span class="input-group-addon">To</span>
                            @*<input id="LodgingTo" class="input-sm form-control input-daterange" name="LodgingTo" value="@ViewBag.dtimestamp">*@
                            <input id="LodgingTo" class="input-sm form-control datepicker" name="LodgingTo" value="@ViewBag.dtimestamp">
                        </div>

                    </div>
                </div>
                <div class="form-group" id="tableMeal">
                    <table class="text-center table-bordered table100" >
                        <thead>
                            <tr>
                                <th class="text-center ebeTable">
                                    Breakfast
                                </th>
                                <th class="text-center ebeTable">
                                    AM Snack
                                </th>
                                <th class="text-center ebeTable">
                                    Lunch
                                </th>
                                <th class="text-center ebeTable">
                                    PM Snack
                                </th>
                                <th class="text-center ebeTable">
                                    Dinner
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="checkbox checkbox-success">
                                        <input id="Breakfast" name="Breakfast" value="True" type="checkbox" checked="" class="ebeBoolean">
                                        <label for="Breakfast"></label>
                                    </div>
                                </td>
                                <td>
                                    <div class="checkbox checkbox-success">
                                        <input id="AmSnack" name="AmSnack" value="True" type="checkbox" checked="" class="ebeBoolean">
                                        <label for="AmSnack"></label>
                                    </div>
                                </td>
                                <td>
                                    <div class="checkbox checkbox-success">
                                        <input id="Lunch" name="Lunch" value="True" type="checkbox" checked="" class="ebeBoolean">
                                        <label for="Lunch"></label>
                                    </div>
                                </td>
                                <td>
                                    <div class="checkbox checkbox-success">
                                        <input id="PmSnack" name="PmSnack" value="True" type="checkbox" checked="" class="ebeBoolean">
                                        <label for="PmSnack"></label>
                                    </div>
                                </td>
                                <td>
                                    <div class="checkbox checkbox-success">
                                        <input id="Dinner" name="Dinner" value="False" type="checkbox" class="ebeBoolean">
                                        <label for="Dinner"></label>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </div>

            <div>
                @*<a asp-action="Index">Back to List</a>*@
            </div>
        </div>
        <div class="row">
            <div class="form-group pull-right">
                <a id="btnAddToList" class="ladda-button btn btn-primary" data-style="expand-left">Add to list</a>
            </div>
        </div>
    </form>
    <div class="">
        <div class="row">
            <div class=" col-sm-12">
                <br />
                <table id="data_table_rec1" class="table table-striped table-bordered table-hover text-center table100">
                    @*<thead>
                        <tr>
                        <th>Action</th>
                        <th>Company</th>
                        <th>Employee ID</th>
                        <th>Passenger Name</th>
                        <th>Position</th>

                        <th>Purpose</th>
                        <th>Remarks</th>
                        <th>Trip Type</th>
                        <th>Breakfast</th>
                        <th>AM Snacks</th>
                        <th>Lunch</th>
                        <th>PM Snacks</th>
                        <th>Dinner</th>
                        <th>Lodging From</th>
                        <th>Lodging To</th>
                        </tr>
                        </thead>
                        <tfoot></tfoot>*@
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ModalEmployeeFilter" tabindex="-1"  role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content modal-col-red">
            <div class="modal-header" style=" padding: 10px 25px 5px 25px!important;border-style: none none solid none;">
                <h4 class="modal-title" id="ModalTitle" style="font-size: 15px;">Passenger Name Filter</h4>
            </div>
            <div class="modal-body">
                <table id="tableEmployee" class="table table-striped table-bordered table-hover table100" >
                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>First Name</th>
                            <th>Middle Name</th>
                            <th>Last Name</th>
                        </tr>
                    </thead>
                    <tfoot></tfoot>
                </table>
            </div>
            <div class="modal-footer">
                <div class="loaded">
                    <button type="button" class="btn btn-danger waves-effect" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}


}

<script>
    function functionToRun(e) {
        var confirmationMessage = "\o/";
        (e || window.event).returnValue = confirmationMessage; //Gecko + IE
        return confirmationMessage;
    }

    window.addEventListener("beforeunload", functionToRun);

    $('#EmployeeSearch').click(function () {

        if ($("#EmployeeNo").is('[disabled]')== false) {
            if ($.trim($("#EmployeeNo").val()) == "") {

                swalAlertOnly("Error", "Invalid employee number", "error");
            }
            else {
                // Start loading
                $('#EmployeeSearch').ladda().ladda('start');



                $.ajax({
                    type: "POST",
                    url: "@Url.Content("~/employees/checkEmployee")?employeeId=" + $.trim($("#EmployeeNo").val()  +"&d=@ViewBag.dGet"),
                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                        if (data.error != 1) {
                          
                            $("#PassengerTypeId").val("1").change();
                            $("#Gender").val(data['data'].gender).trigger("change");
                            $("#Nationality").val(data.nationalityName).trigger("change");
                            $("#FirstName").val(data['data'].firstName);
                            $("#MiddleName").val(data['data'].middleName);
                            $("#LastName").val(data['data'].lastName);
                            $("#Position").val(data['data'].position);
                            $("#CompanyListId").val(data['data'].companyListId).change();
                            $("#ChargingCompanyId").val(data['data'].chargingCompanyId).change();
                            $("#ContactNo").val(data['data'].mobileNumber).change();
                            $("#ChargingDepartmentId").append("<option value='" + data.chargingDepartmentId + "'>" + data.chargingDepartment + "</option>").val(data.chargingDepartmentId).change();
                            CheckCompanyList();
                            DisableLookupElement();


                        } else {
                            $("#Name").val("");
                            $("#Position").val("");
                            $("#CompanyListId").val("");
                            swalAlertOnly("Error", "Employee not found", "error");
                        }

                        $('#EmployeeSearch').ladda().ladda('stop');
                    }
                });


            }
        }
    });


    function checkLodging(e) {

        switch (e.value) {
            case 1:
            case '1':
                $("#Breakfast").prop("checked", "checked");
                $("#AmSnack").prop("checked", "checked");
                $("#Lunch").prop("checked", "checked");
                $("#PmSnack").prop("checked", "checked");
                $("#Dinner").prop("checked", "");

                $("#Breakfast").val("True");
                $("#AmSnack").val("True");
                $("#Lunch").val("True");
                $("#PmSnack").val("True");
                $("#Dinner").val("False");



                $("#tableMeal").removeClass("hidden");
                $("#Lodgingdatepicker").addClass('hidden');
                break;
            case 2:
            case '2':
                $("#Breakfast").prop("checked", "checked");
                $("#AmSnack").prop("checked", "checked");
                $("#Lunch").prop("checked", "checked");
                $("#PmSnack").prop("checked", "checked");
                $("#Dinner").prop("checked", "checked");

                $("#Breakfast").val("True");
                $("#AmSnack").val("True");
                $("#Lunch").val("True");
                $("#PmSnack").val("True");
                $("#Dinner").val("True");

                $("#tableMeal").removeClass("hidden");
                $("#Lodgingdatepicker").removeClass('hidden');
                break;
            case 3:
            case '3':

                $("#Breakfast").prop("checked", "");
                $("#AmSnack").prop("checked", "");
                $("#Lunch").prop("checked", "");
                $("#PmSnack").prop("checked", "");
                $("#Dinner").prop("checked", "");

                $("#Breakfast").val("False");
                $("#AmSnack").val("False");
                $("#Lunch").val("False");
                $("#PmSnack").val("False");
                $("#Dinner").val("False");

                $("#tableMeal").addClass("hidden");
                $("#Lodgingdatepicker").addClass('hidden');
                break;
            default:
                break;
        }


    }

    $(".ebeBoolean").on('change', function () {
        if ($(this).is(':checked')) {
            $(this).attr('value', 'true');
        } else {
            $(this).attr('value', 'false');
        }
    });


    //$('.input-daterange').datepicker({
    //    keyboardNavigation: false,
    //    forceParse: false,
    //    autoclose: true
    //});

    $('.datepicker').datepicker({
        keyboardNavigation: false,
        forceParse: false,
        autoclose: true,
        todayHighlight: false,
        startDate: "@ViewBag.dtimestamp"
    });


    @*var table1 = $('#data_table_rec1').DataTable({
        "processing": true,
        "serverSide": true,
        "ordering": false,
        "autoWidth": true,
        "ajax": {
            "url": "@Url.Content("~/shuttlepassengers/ShowPassengerLists")",
            "type": "POST",
            "data": function (d) {
                var dtimestamp = @ViewBag.dGet;
                d.timestamp = dtimestamp/1000;
            }

        },
        "columns": [
            { "data": "no", title: "ID", width: "5%", orderable: true },
            { "data": "name", title: "Name", orderable: false },
            { "data": "contactNumber", title: "Contact Number", orderable: false },
            { "data": "status", title: "Status", orderable: false },
            { "data": "remarks", title: "Remarks", orderable: false },
        ],
        'select': {
            'style': 'single'
        },
        'order': [[0, 'desc']]
    });*@


    var table1 = $('#data_table_rec1').DataTable({
        "processing": false,
        "serverSide": true,
        "autoWidth": false,
        "searching": false,
        "scrollX": true,
        "bLengthChange": false,
        "ajax": {
            "url": "@Url.Content("~/shuttlepassengers/ShowPassengerLists")",
            "type": "POST",
            "data": function (d) {
                var dtimestamp = @ViewBag.dget;
                d.timestamp = dtimestamp;
            }
        },
        "columns": [
            { "data": "id", title: "Action",width: "5%",align:"center", orderable: false},
            { "data": "company", title: "Company", orderable: false },
            { "data": "employeeID", title: "Employee No", orderable: false },
            { "data": "passengerName", title: "Passenger Name", orderable: false },
            { "data": "position", title: "Position", orderable: false },
            { "data": "purpose", title: "Purpose", orderable: false },
            { "data": "remarks", title: "Remarks", orderable: false },
            { "data": "tripType", title: "Trip Type", orderable: false },
            { "data": "breakfast", title: "Breakfast", orderable: false },
            { "data": "amSnacks", title: "AM Snacks", orderable: false },
            { "data": "lunch", title: "Lunch", orderable: false },
            { "data": "pmSnacks", title: "PM Snacks", orderable: false },
            { "data": "dinner", title: "Dinner", orderable: false },
            { "data": "lodgingFrom", title: "Lodging From", orderable: false },
            { "data": "lodgingTo", title: "Lodging To", orderable: false },
        ]
        ,
        'select': {
            'style': 'single'
        },
        'columnDefs': [
            {
                "targets": "_all", // your case first column
                "className": "text-center",
            }],
        "order": [[0, "desc"]]
    });




    var atl = $('#btnAddToList').ladda();
    atl.click(function () {

        $('#CompanyOther').validate();
        $('#EmployeeNo').validate();
        $("#ChargingCompanyId").select2('destroy');
        $("#ChargingDepartmentId").select2('destroy');
        //$("#CompanyListId").select2('destroy');
        $("#TripTypeId").select2('destroy');

        $("#ChargingCompanyId").removeAttr("disabled");
        $("#ChargingDepartmentId").removeAttr("disabled");
        $("#Gender").removeAttr("disabled");
        if ($("#btnAddToList").is('[disabled]') == false) {
            if ($("form").valid()) {

                $("#ModalLoading").modal("show");
                $("#ModalLoading").css('display', 'block');
                $(".select2").select2({ placeholder: "Please Select" });
                EnableLookupElement();
                // Start loading
                atl.ladda('start');

                $.ajax({
                    type: "POST",
                    url: "@Url.Content("~/shuttlepassengers/create")",
                    data: $("#ShuttleForm").serialize(),
                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {

                        $("#ModalLoading").css('display', 'none');

                        if (data.success == 1) {
                            window.addEventListener("beforeunload", functionToRun);
                            $('#ShuttleForm').trigger("reset");
                            // $(".select2").select2("val", "");
                            //$("#CompanyListId").select2({
                            //    width:
                            //});

                            ValidatePassengerType();
                            CheckCompanyList();


                            $("#TripTypeId").val("1").trigger("change");
                            $('#data_table_rec1').DataTable().clear().draw();
                            $('#data_table_rec1').DataTable().ajax.reload();

                            $(".select2").select2({ placeholder: "Please Select",width: "100%" });
                            //location.reload();
                            swalAlertOnly("Success", data.message, "success");
                        } else {
                            swalAlertOnly("Error", data.message, "error");
                            DisableLookupElement();
                        }

                        atl.ladda('stop');
                          var checkifapprover = "@ViewBag.OverAllApprover";
                        if (checkifapprover != "1") {
                            $("#ChargingCompanyId").attr("disabled", true);
                            $("#ChargingDepartmentId").attr("disabled", true);
                        }

                    }
                });


            }
            else {

                $('.field-validation-error:first').parent().find(':input').focus();

                $(".select2").select2({ placeholder: "Please Select" });
            }
        }

    });

    function ShowEmployeeByName() {



        if ($.trim($("#FirstName").val()) == "" && $.trim($("#MiddleName").val()) == "" && $.trim($("#LastName").val()) == "") {
            swalAlertOnly("Error", "Invalid employee name", "error");
        }
        else {

            $('#tableEmployee').DataTable().clear().draw();
            $('#tableEmployee').DataTable().ajax.reload();
            $("#ModalEmployeeFilter").modal("show");
            setTimeout(function () {
                $('#tableEmployee').DataTable().columns.adjust().responsive.recalc();
            },500);
        }
    }

    $('#tableEmployee').DataTable({
        "processing": false,
        "serverSide": true,
        "autoWidth": false,
        "searching": false,
        "scrollX": true,
        "bLengthChange": false,
        "ajax": {
